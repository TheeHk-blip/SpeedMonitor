<Window x:Class="SpeedMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpeedMonitor"
        mc:Ignorable="d"
        Title="SpeedMonitor" 
        Icon="pack://application:,,,/SpeedMonitor.ico"
        MinHeight="15"         
        MinWidth="130"  
        Width="180"
        Height="20"        
        Topmost="True" 
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"      
        WindowStyle="None"
        >
    <Border Background="#CC1E1E1E" CornerRadius="4" BorderBrush="#33FFFFFF" BorderThickness="1" >
        <Grid>
            <Grid.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Header="Start with windows"    
                        Name="StartupMenuItem"
                        IsCheckable="True"
                        Checked="Startup_Checked"
                        Unchecked="Startup_Unchecked"
                    />
                    <MenuItem Header="Display Mode" >
                        <MenuItem Header="Show Both" Name="MenuShowBoth" IsCheckable="True" IsChecked="True" Click="DisplayMode_Click"/>
                        <MenuItem Header="Download Only" Name="MenuShowDl" IsCheckable="True" Click="DisplayMode_Click"/>
                        <MenuItem Header="Upload Only" Name="MenuShowUl" IsCheckable="True" Click="DisplayMode_Click"/>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit Application" Click="Exit_Click" />
                </ContextMenu>
            </Grid.ContextMenu>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Name="DlLabel" Text="↓ 0B" FontSize="12" FontWeight="SemiBold" Foreground="#06b6d4" Margin="4,0,6,0"/>
                <TextBlock Name="UlLabel" Text="↑ 0B" FontSize="12" FontWeight="SemiBold" Foreground="#84cc16" Margin="4,0,6,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>